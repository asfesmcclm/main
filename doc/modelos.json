
  "m1": {
    "titulo": "1. Permiso Parental (hasta 8 semanas) - Art. 48 bis ET",
    "uso": "Permiso parental para cuidado de menor hasta 8 años. Derecho individual. Puede disfrutarse de forma flexible. ACTUALIZACIÓN 2025: 2 semanas retribuidas al 100% por la Seguridad Social (4 semanas en monoparental), las restantes sin retribución. Protección contra despido.",
    "variables": ["empresa", "localidad", "fecha", "nombre", "dni", "email", "telefono", "fecha_nacimiento", "semanas", "monoparental", "modalidad", "fecha_inicio", "fecha_fin", "motivo"],
    "plantilla": "A la Dirección de la empresa: {empresa}\nEn {localidad}, a {fecha}\n\nAsunto: Comunicación de disfrute de Permiso Parental (Art. 48 bis ET)\n\nD./Dña. {nombre} con DNI {dni}\nEmail: {email}\nTeléfono: {telefono}\n\nLes comunico que, en virtud del art. 48 bis del Estatuto de los Trabajadores, disfrutaré del permiso parental para el cuidado de mi hijo/a nacido/a el {fecha_nacimiento}.\n\nDATOS DEL PERMISO:\n• Duración: {semanas} semanas\n• Retribución: 2 semanas retribuidas al 100% por la Seguridad Social + 6 semanas sin retribución (RD-ley 9/2025)\n• Familia monoparental: {monoparental}\n• Modalidad: {modalidad}\n• Fecha inicio: {fecha_inicio}\n• Fecha fin: {fecha_fin}\n• Motivo específico: {motivo}\n\nSe comunica con la antelación legalmente prevista (15 días o la establecida en convenio colectivo).\n\nAtentamente,\nFdo: {nombre}"
  },
  "m2": {
    "titulo": "2. Adaptación de Puesto (Art. 25 LPRL)",
    "uso": "Protección de trabajadores especialmente sensibles a riesgos laborales por razones de salud, embarazo u otras condiciones personales.",
    "variables": ["empresa", "localidad", "fecha", "nombre", "dni", "email", "telefono", "puesto", "motivo"],
    "plantilla": "A la Dirección de la empresa: {empresa}\nEn {localidad}, a {fecha}\n\nAsunto: Solicitud de evaluación y adaptación de puesto (Art. 25 LPRL)\n\nD./Dña. {nombre} con DNI {dni}\nEmail: {email}\nTeléfono: {telefono}\n\nEn virtud del Art. 25 de la Ley de Prevención de Riesgos Laborales, solicito la evaluación de mi puesto de trabajo ({puesto}) y la adopción de las medidas preventivas necesarias debido a: {motivo}.\n\nAtentamente,\nFdo: {nombre}"
  },
  "m3": {
    "titulo": "3. Hospitalización Recién Nacido (Art. 37.4 ET)",
    "uso": "Derecho a ausencia de 1 hora o reducción de jornada hasta 2 horas con disminución proporcional de salario por hospitalización del recién nacido tras el parto.",
    "variables": ["empresa", "localidad", "fecha", "nombre", "dni", "email", "telefono", "fecha_nacimiento", "modalidad"],
    "plantilla": "A la Dirección de la empresa: {empresa}\nEn {localidad}, a {fecha}\n\nAsunto: Comunicación de derecho por hospitalización de recién nacido (Art. 37.4 ET)\n\nD./Dña. {nombre} con DNI {dni}\nEmail: {email}\nTeléfono: {telefono}\n\nComunico que, encontrándose mi hijo/a nacido el {fecha_nacimiento} hospitalizado a continuación del parto, hago uso de mi derecho a {modalidad} conforme al Art. 37.4 del ET.\n\nAtentamente,\nFdo: {nombre}"
  },
  "m4": {
    "titulo": "4. Exámenes Prenatales y Preparación (Art. 37.3.f ET)",
    "uso": "Permiso retribuido por el tiempo indispensable para exámenes prenatales y técnicas de preparación al parto.",
    "variables": ["empresa", "localidad", "fecha", "nombre", "dni", "email", "telefono", "fecha_inicio", "motivo"],
    "plantilla": "A la Dirección de la empresa: {empresa}\nEn {localidad}, a {fecha}\n\nAsunto: Ausencia retribuida por exámenes prenatales/preparación al parto (Art. 37.3.f ET)\n\nD./Dña. {nombre} con DNI {dni}\nEmail: {email}\nTeléfono: {telefono}\n\nComunico que el día {fecha_inicio} me ausentaré de mi puesto por el tiempo indispensable para: {motivo}, aportando el justificante correspondiente.\n\nAtentamente,\nFdo: {nombre}"
  },
  "m5": {
    "titulo": "5. Excedencia Voluntaria (Art. 46.2 ET)",
    "uso": "Para personas trabajadoras con al menos un año de antigüedad. Duración entre 4 meses y 5 años.",
    "variables": ["empresa", "localidad", "fecha", "nombre", "dni", "email", "telefono", "fecha_inicio", "fecha_fin"],
    "plantilla": "A la Dirección de la empresa: {empresa}\nEn {localidad}, a {fecha}\n\nAsunto: Solicitud de excedencia voluntaria (Art. 46.2 ET)\n\nD./Dña. {nombre} con DNI {dni}\nEmail: {email}\nTeléfono: {telefono}\n\nSolicito mi paso a la situación de excedencia voluntaria desde el día {fecha_inicio} hasta el {fecha_fin}.\n\nAtentamente,\nFdo: {nombre}"
  },
  "m6": {
    "titulo": "6. Formación Profesional (20 horas) - Art. 23.3 ET",
    "uso": "Derecho a 20 horas anuales de formación vinculada al puesto, acumulables hasta 5 años. Requiere al menos 1 año de antigüedad. Es un permiso retribuido, no obligación de la empresa de impartir formación.",
    "variables": ["empresa", "localidad", "fecha", "nombre", "dni", "email", "telefono", "motivo", "fecha_inicio"],
    "plantilla": "A la Dirección de la empresa: {empresa}\nEn {localidad}, a {fecha}\n\nAsunto: Solicitud de permiso retribuido para formación (Art. 23.3 ET)\n\nD./Dña. {nombre} con DNI {dni}\nEmail: {email}\nTeléfono: {telefono}\n\nSolicito el disfrute de horas de formación acumuladas para realizar la actividad formativa: {motivo}, vinculada a la actividad de la empresa, con inicio el día {fecha_inicio}.\n\nAtentamente,\nFdo: {nombre}"
  },
  "m7": {
    "titulo": "7. Fin de Permiso y Reincorporación",
    "uso": "Comunicación de reincorporación tras excedencia o permiso.",
    "variables": ["empresa", "localidad", "fecha", "nombre", "dni", "email", "telefono", "motivo", "fecha_inicio"],
    "plantilla": "A la Dirección de la empresa: {empresa}\nEn {localidad}, a {fecha}\n\nAsunto: Comunicación de reincorporación tras {motivo}\n\nD./Dña. {nombre} con DNI {dni}\nEmail: {email}\nTeléfono: {telefono}\n\nComunico mi reincorporación a mi puesto de trabajo el día {fecha_inicio}.\n\nAtentamente,\nFdo: {nombre}"
  },
  "m8": {
    "titulo": "8. Lactancia (Art. 37.4 ET)",
    "uso": "Derecho a una hora de ausencia, reducción de jornada o acumulación en jornadas completas. ACTUALIZACIÓN 2024: La modalidad de disfrute es decisión del trabajador, sin necesidad de acuerdo con la empresa (RD-ley 2/2024).",
    "variables": ["empresa", "localidad", "fecha", "nombre", "dni", "email", "telefono", "fecha_nacimiento", "parto_multiple", "fecha_inicio", "fecha_fin"],
    "plantilla": "A la Dirección de la empresa: {empresa}\nEn {localidad}, a {fecha}\n\nAsunto: Ejercicio del derecho de lactancia (Art. 37.4 ET)\n\nD./Dña. {nombre} con DNI {dni}\nEmail: {email}\nTeléfono: {telefono}\n\nComunico mi decisión de ejercer el derecho de lactancia respecto a mi hijo/a nacido el {fecha_nacimiento}, optando por la modalidad de acumulación en jornadas completas.\n\nConforme al Art. 37.4 ET modificado por RD-ley 2/2024, la decisión sobre la modalidad de disfrute corresponde al trabajador.\n\nInicio: {fecha_inicio}\nFin: {fecha_fin}\n\nAtentamente,\nFdo: {nombre}"
  },
  "m9": {
    "titulo": "9. Adaptación de Jornada (Art. 34.8 ET)",
    "uso": "Solicitud de adaptación de jornada y forma de trabajo para conciliación familiar. La empresa debe contestar en 15 días. Protección contra despido.",
    "variables": ["empresa", "localidad", "fecha", "nombre", "dni", "email", "telefono", "puesto", "departamento", "edad_menor", "parentesco", "motivo"],
    "plantilla": "A la Dirección de la empresa: {empresa}\nEn {localidad}, a {fecha}\n\nAsunto: Solicitud de adaptación de jornada (Art. 34.8 ET)\n\nD./Dña. {nombre} con DNI {dni}\nEmail: {email}\nTeléfono: {telefono}\nPuesto: {puesto} / Depto: {departamento}\n\nSolicito la adaptación de mi jornada por cuidado de {parentesco} de {edad_menor} años.\n\nPROPUESTA:\n{motivo}\n\nQuedo a la espera del inicio del periodo de negociación previsto legalmente (la empresa debe contestar en un plazo máximo de 15 días).\n\nAtentamente,\nFdo: {nombre}"
  },
  "m10": {
